# Ignore the runs/ tree by default — experiment outputs (figures, parquets,
# LaTeX artifacts, h5ad caches) are not source. EXCEPTION: per the scivcd
# interop governance design, runs/<run_id>/audit/baseline.json must be
# committable so the pre-commit hook can auto-stage non-CRITICAL deltas in
# the same commit as the figure change. Git requires cascading negations to
# re-include a file once any parent has been excluded.
runs/*
!runs/*/
runs/*/*
!runs/*/audit/
runs/*/audit/*
!runs/*/audit/baseline.json

# Scanpy's default download cache for sc.datasets.* (e.g. paul15) — fresh-run
# demos materialize this; never source.
data/
__pycache__/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.aux
*.log
*.synctex.gz
.cache/
*.egg-info/
dist/
build/
.coverage

# OMC session ephemera. Internal planning specs under .omc/specs/ are not
# part of the public distribution and must not be tracked; everything here
# regenerates from session state.
.omc/specs/
.omc/state/
.omc/handoffs/
.omc/sessions/
.omc/__pycache__/
.omc/notepad.md
.omc/project-memory.json
.omc/scivcd_audit_driver.py

